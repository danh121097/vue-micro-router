{
  "name": "vue-micro-router",
  "version": "1.0.0",
  "type": "module",
  "description": "Mobile-app-style navigation for Vue 3 — animated page stacks, modal dialogs, HUD controls. No URL routing.",
  "author": {
    "name": "Danh Nguyen",
    "url": "https://harrynguyen.work"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danh121097/vue-micro-router.git"
  },
  "homepage": "https://github.com/danh121097/vue-micro-router#readme",
  "bugs": {
    "url": "https://github.com/danh121097/vue-micro-router/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "router",
    "micro-router",
    "segment-router",
    "dialog",
    "modal",
    "navigation",
    "state-management"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./audio": {
      "types": "./dist/audio.d.ts",
      "import": "./dist/audio.mjs"
    },
    "./styles": "./dist/styles.css"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": ["*.css"],
  "peerDependencies": {
    "vue": "^3.4.0",
    "howler": "^2.2.0",
    "@vue/devtools-api": "^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "howler": {
      "optional": true
    },
    "@vue/devtools-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "bun test",
    "bench": "bun run benchmarks/navigation-bench.ts",
    "bench:size": "bun run benchmarks/bundle-size-check.ts",
    "dev:example": "vite --config examples/vite.config.ts examples",
    "prepublishOnly": "bun run build"
  }
}
