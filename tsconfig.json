{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./libs",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./libs/*"]
    }
  },
  "include": ["libs/**/*.ts", "libs/**/*.vue"],
  "exclude": ["node_modules", "dist"]
}
