{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["bun-types"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./libs/*"]
    }
  },
  "include": [
    "libs/**/*.ts",
    "libs/**/*.vue",
    "examples/**/*.ts",
    "examples/**/*.vue",
    "tests/**/*.ts",
    "vue-micro-router.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
